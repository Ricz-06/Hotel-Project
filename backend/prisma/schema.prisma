generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum TipoCliente {
  Normal
  Deluxe
  VIP
}

enum TipoHabitacion {
  Normal
  Deluxe
  VIP
}

enum EstadoHabitacion {
  Libre
  ocupada
}

enum EstadoSolicitud {
  pendiente
  aprobada
  rechazada
}

model Usuario {
  id       Int         @id @default(autoincrement())
  nombre   String
  correo   String      @unique
  password String
  role     Role        @default(USER)

  verificado         Boolean @default(false)
  codigoVerificacion String?

  @@map("usuarios")
}

model Cliente {
  id           Int              @id @default(autoincrement())
  nombre       String
  tipo         TipoCliente      @default(Normal)
  habitaciones Habitacion[]

  @@map("clientes")
}

model Habitacion {
  id        Int              @id @default(autoincrement())
  numero    Int              @unique
  tipo      TipoHabitacion   @default(Normal)
  estado    EstadoHabitacion @default(Libre)
  servicios String[]
  clienteId Int?
  cliente   Cliente?         @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@map("habitaciones")
}

model Solicitud {
  id              Int             @id @default(autoincrement())
  nombre          String
  correo          String
  telefono        String
  tipo_habitacion String
  estado          EstadoSolicitud @default(pendiente)
  creadoEn        DateTime        @default(now())

  @@map("solicitudes")
}

model Factura {
  id       Int      @id @default(autoincrement())
  cliente  String
  correo   String
  telefono String
  servicio String
  subtotal Float
  iva      Float
  total    Float
  creadoEn DateTime @default(now())

  @@map("facturas")
}
